  painelDialogo: {fileID: 854474810}
  txtNome: {fileID: 1781053804}
  txtFala: {fileID: 2124770231}
  tempoPorFala: 4
  falasCena1Universidade:
  - nome: Protagonista (pensando)
    texto: "Tudo ficou t\xE3o silencioso\u2026"
  - nome: Protagonista (pensando)
    texto: "Eu ainda tinha tanta coisa pra viver\u2026"
  - nome: Protagonista (pensando)
    texto: "Sonhos\u2026 planos\u2026 tudo acabou antes de come\xE7ar."
  - nome: Protagonista (pensando)
    texto: "Se existisse\u2026 qualquer chance\u2026 eu agarraria sem pensar."
  falasCena2LabAproximacao:
  - nome: Protagonista
    texto: "\u2026O que \xE9 isso?"
  - nome: Sistema
    texto: '[ Aperte E para descobrir ]'
  falasCena2LabInteracao:
  - nome: Protagonista
    texto: "Espera\u2014 o que est\xE1 acontecendo?!"
