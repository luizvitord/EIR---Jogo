  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: BorinDepois
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Borin Stoneheart
    text: "\"Aetherion est\xE1 esperando.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: '"O castelo fica a nordeste desta casa."'
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"Siga a estrada at\xE9 as torres negras.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"O destino de Eldrath est\xE1 atr\xE1s daqueles port\xF5es.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
