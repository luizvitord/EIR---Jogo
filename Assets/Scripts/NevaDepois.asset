  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: NevaDepois
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: N.E.V.A
    text: "\"Sele\xE7\xE3o confirmada.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Curioso."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Entre todos os artefatos poss\xEDveis...\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Foi este que voc\xEA escolheu.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Humanos raramente mudam."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Mesmo quando atravessam mundos..."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Continuam buscando as mesmas coisas."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Vida."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Esperan\xE7a.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Mais tempo."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Transfer\xEAncia autorizada.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Preparando retorno ao mundo de origem."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Adeus, Kuro."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Ou talvez..."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"At\xE9 breve.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
