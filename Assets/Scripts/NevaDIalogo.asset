%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: NevaDIalogo
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: N.E.V.A
    text: "\"Protocolo conclu\xEDdo.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Objetivo alcan\xE7ado.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Artefato recuperado."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Anomalia identificada.\n\nIndiv\xEDduo: Kuro.\nEstado: compat\xEDvel.
      \""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: Kuro
    text: "\"Como voc\xEA sabe meu nome?\""
    portrait: {fileID: 4376683403823288874, guid: e3910ad15a016dc4d9f921246200f9e5, type: 3}
  - name: N.E.V.A
    text: "\"Essa informa\xE7\xE3o n\xE3o \xE9 relevante.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: Kuro
    text: "\"O que voc\xEA \xE9?\""
    portrait: {fileID: 4376683403823288874, guid: e3910ad15a016dc4d9f921246200f9e5, type: 3}
  - name: N.E.V.A
    text: "\"N.E.V.A.\n\nN\xFAcleo de Execu\xE7\xE3o para Vari\xE1veis Adaptativas.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: "\"Selecione um item para transfer\xEAncia.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: Kuro
    text: "\"Transfer\xEAncia?\""
    portrait: {fileID: 4376683403823288874, guid: e3910ad15a016dc4d9f921246200f9e5, type: 3}
  - name: N.E.V.A
    text: "\"A janela de retorno est\xE1 aberta.\""
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: N.E.V.A
    text: '"Tempo restante: limitado."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
  - name: Kuro
    text: '"Retorno..."'
    portrait: {fileID: 4376683403823288874, guid: e3910ad15a016dc4d9f921246200f9e5, type: 3}
  - name: N.E.V.A
    text: '"Escolha."'
    portrait: {fileID: 9153910854962203350, guid: a495104697295704899a1ba0a72df220, type: 3}
