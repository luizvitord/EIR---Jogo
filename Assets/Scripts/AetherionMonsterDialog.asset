  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: AetherionMonsterDialog
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Aetherion
    text: '"Acabou?"'
    portrait: {fileID: 21300000, guid: 4ae6914d02d800d4884d960ee0922b74, type: 3}
  - name: Aetherion
    text: "\"Voc\xEA realmente acreditou nisso?\""
    portrait: {fileID: 21300000, guid: 4ae6914d02d800d4884d960ee0922b74, type: 3}
  - name: Aetherion
    text: '"O rei foi apenas o recipiente."'
    portrait: {fileID: 21300000, guid: 4ae6914d02d800d4884d960ee0922b74, type: 3}
  - name: Aetherion
    text: '"Agora..."'
    portrait: {fileID: 21300000, guid: 4ae6914d02d800d4884d960ee0922b74, type: 3}
  - name: Aetherion
    text: '"Contemple minha verdadeira forma."'
    portrait: {fileID: 21300000, guid: 4ae6914d02d800d4884d960ee0922b74, type: 3}
