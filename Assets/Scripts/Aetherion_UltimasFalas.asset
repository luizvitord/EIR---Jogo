MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: Aetherion_UltimasFalas
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Aetherion
    text: "\"As colheitas... Este ano ser\xE3o boas...\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"Diga aos alde\xF5es...\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"Que n\xE3o precisam mais se preocupar...\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"N\xF3s conseguimos...\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: '"Encontramos a cura..."'
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"Lyanna... \xC9 voc\xEA mesmo?\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"Voc\xEA est\xE1 vendo?\""
    portrait: {fileID: 21300000, guid: 206f1faf2d48eae4fbe03bffead722be, type: 3}
  - name: Aetherion
    text: "\"As crian\xE7as est\xE3o brincando de novo...\""
    portrait: {fileID: 2422184869279653374, guid: 29b318b1722a727428db6be099888044, type: 3}
  - name: Aetherion
    text: '"Espere mais um pouco, querida..."'
    portrait: {fileID: 2422184869279653374, guid: 29b318b1722a727428db6be099888044, type: 3}
  - name: Aetherion
    text: '"Estou indo..."'
    portrait: {fileID: 2422184869279653374, guid: 29b318b1722a727428db6be099888044, type: 3}
