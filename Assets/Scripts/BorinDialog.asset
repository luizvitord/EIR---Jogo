--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: BorinDialog
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Borin Stoneheart
    text: "\"Indo para o sal\xE3o principal, garoto?\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"Cuidado com o que vai encontrar l\xE1 dentro.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: '"Aetherion nem sempre foi um monstro."'
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: '"Ele era o nosso Rei... Um homem bom..."'
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"Desesperado para salvar seu povo de uma praga que destru\xEDa Eldrath.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: '"Ele buscou a Fonte, a cura perfeita..."'
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"Mas o poder da Fonte n\xE3o foi feito para a alma de um mortal.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"A ambi\xE7\xE3o e o desespero o consumiram de dentro para fora.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"N\xF3s acreditamos nele. Seguimos suas ordens... E assistimos Eldrath
      cair junto com ele.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: "\"Se for enfrent\xE1-lo... Fa\xE7a um favor para todos n\xF3s.\""
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
  - name: Borin Stoneheart
    text: '"Traga paz a ele."'
    portrait: {fileID: 1218904397364024121, guid: 648921ba3cbed694c8e8a85b6a573597, type: 3}
