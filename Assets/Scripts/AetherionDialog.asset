--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b74d54b91df6594a9d4842a420a3693, type: 3}
  m_Name: AetherionDialog
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Aetherion
    text: "\"Ent\xE3o foi voc\xEA quem chegou t\xE3o longe.\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Kuro
    text: "\"Voc\xEA \xE9 Aetherion?\""
    portrait: {fileID: 3451869356938701982, guid: 4d95c7377abe48e42a1661a5d062ad81, type: 3}
  - name: Aetherion
    text: "\"J\xE1 fui... Hoje sou apenas o que restou dele.\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Kuro
    text: "\"As pessoas l\xE1 fora ainda sofrem por sua causa.\""
    portrait: {fileID: 3451869356938701982, guid: 4d95c7377abe48e42a1661a5d062ad81, type: 3}
  - name: Aetherion
    text: '"Sofrimento? Hahahaha"

'
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: "\"Um pre\xE7o insignificante diante da eternidade.\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Kuro
    text: "\"Voc\xEA destruiu seu pr\xF3prio reino.\""
    portrait: {fileID: 3451869356938701982, guid: 4d95c7377abe48e42a1661a5d062ad81, type: 3}
  - name: Aetherion
    text: '"Porque eles eram fracos."'
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: '"A Fonte oferece poder."'
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: "\"Mas os fracos sempre chamam poder de maldi\xE7\xE3o.\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: '"Diga-me..."  '
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: "\"Se existisse uma cura para a sua pr\xF3pria morte...\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Aetherion
    text: "\"Voc\xEA realmente faria diferente?\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
  - name: Kuro
    text: "\"Voc\xEA se tornou um monstro.\""
    portrait: {fileID: 3451869356938701982, guid: 4d95c7377abe48e42a1661a5d062ad81, type: 3}
  - name: Aetherion
    text: "\"E ainda assim... Eu continuo de p\xE9.\""
    portrait: {fileID: 21300000, guid: 89c61d2019ff0254ab0982fbc450d110, type: 3}
