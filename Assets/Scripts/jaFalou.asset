  m_Name: jaFalou
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  talkScript:
  - name: Elandrya
    text: "\"Ainda est\xE1 aqui?\""
    portrait: {fileID: 4712645955169456435, guid: ca40c64160fa6484a935cf577861ae70, type: 3}
  - name: Elandrya
    text: '"Se deseja compreender este mundo, procure Durgan Ironvein."'
    portrait: {fileID: 4712645955169456435, guid: ca40c64160fa6484a935cf577861ae70, type: 3}
  - name: Elandrya
    text: "\"A ferraria fica na entrada de Valedorn. Voc\xEA ouvir\xE1 as marteladas
      antes mesmo de v\xEA-la.\""
    portrait: {fileID: -2625695072606700060, guid: 7f0d94d186ce71744ada88822b6f786b, type: 3}
